{
  "$schema": "https://raw.githubusercontent.com/nicholasrice/tauri/feat/permissions-schema/crates/tauri-utils/schema/capability.json",
  "identifier": "default",
  "description": "Default capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "store:default",
    "shell:allow-open",
    "dialog:default",
    "fs:default",
    "autostart:default",
    "updater:default",
    "process:default"
  ]
}
